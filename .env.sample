# Client Configuration
# The full URL of the server API
API_ENDPOINT=http://localhost:5432

# Server Configuration
# The port the server listens on
SERVER_PORT=5432
# The host/interface the server binds to (0.0.0.0 for all interfaces)
SERVER_BIND_HOST=0.0.0.0

# Security
JWT_SECRET=your_jwt_secret_here

USE_VPN=false

# Auth token/session lifetimes
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7
SESSION_TTL_DAYS=7

# Redis connection URI.
# The server reads this value from .env first, then falls back to the process
# environment variable of the same name.
REDIS_URI=redis://localhost:6379
